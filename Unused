document.addEventListener("DOMContentLoaded", async () => {
    // Load header
    fetch('header.html')
        .then(res => res.text())
        .then(html => document.getElementById('navbar').innerHTML = html);

    // Load data once
    const coins = await loadCoins();
    const caps = await loadCaps();

    // Containers
    const coinContainer = document.getElementById("CoinGrid");
    const capContainer = document.getElementById("CapGrid");

    // Helper: create card
    const createCard = (item, type) => {
        const card = document.createElement("div");
        card.classList.add(type + "Card");
        card.innerHTML = `
            <img loading="lazy" class="${type}Image" src="assets/images/firstLoad.png" width="75" height="75" alt="${type}Image">
        `;
        const img = card.querySelector(`.${type}Image`);
        const loader = type === "coin" ? loadCoinImages : loadCapImages;
        loader(item.ID || item.Name).then(blob => {
            img.src = URL.createObjectURL(blob);
            card.title = Object.entries(item)
                .map(([k, v]) => `${k}: ${v}`)
                .join("\n");
        });
        img.onerror = () => card.style.display = "none";
        return card;
    };

    // Render all coins and caps
    coins.forEach(c => coinContainer.appendChild(createCard(c, "coin")));
    caps.forEach(c => capContainer.appendChild(createCard(c, "cap")));

    // Calculate total value of coins
    let pence = 0, pounds = 0, euroCents = 0, euros = 0;
    coins.forEach(c => {
        const val = Number(c.Denomination) * Number(c.Quantity);
        switch (c.Currency) {
            case "Pence": pence += val; break;
            case "Pound": pounds += val; break;
            case "Euro Cent": euroCents += val; break;
            case "Euro": euros += val; break;
        }
    });
    const totalPounds = pounds + pence / 100;
    const totalEuros = euros + euroCents / 100;
    const total = totalPounds + totalEuros * 0.87;

    document.getElementById("TotalContainer").innerHTML =
        `<p style="margin-left:2em; border:.5em dashed #000">Estimated Total Value: £${total.toFixed(2)} GBP</p>`;

    // Search functionality
    const displaySearch = async (data, containerId, loader, type, search) => {
        const container = document.getElementById(containerId);
        container.innerHTML = "";
        let found = false;
        data.forEach(item => {
            if (Object.values(item).some(v => v?.toString().toLowerCase().includes(search.toLowerCase()))) {
                found = true;
                container.appendChild(createCard(item, type));
            }
        });
        document.getElementById(type === "coin" ? "CoinSearchDisplaySeperation" : "CapSearchDisplaySeperation").style.display =
            found ? "block" : "none";
    };

    document.getElementById("coinSearch").addEventListener("keyup", e => 
        displaySearch(coins, "CoinSearchDisplay", loadCoinImages, "coin", e.target.value)
    );

    document.getElementById("capSearch").addEventListener("keyup", e =>
        displaySearch(caps, "CapSearchDisplay", loadCapImages, "cap", e.target.value)
    );
});

async function loadCapImages(search) {
    search = search.concat(".png");
    try {
        const response = await fetch(`assets/capImages/${search}`);
        return response.blob();
    } catch (err) {
        console.error("Error loading Caps:", err);
    }
}

async function loadCaps() {
    try {
        const response = await fetch("assets/Caps.csv");
        const text = await response.text();

        const result = Papa.parse(text, {
            header: true,
            skipEmptyLines: true,
        });

        return result.data;
    } catch (err) {
        console.error("Error loading Caps:", err);
    }
}

async function loadCoinImages(search) {
    search = search.concat(".png");
    try {
        const response = await fetch(`assets/coinImages/${search}`);
        return await response.blob();
    } catch (err) {
        console.error("Error loading Coins:", err);
    }
}

async function loadCoins() {
    try {
        const response = await fetch("assets/Coins.csv");
        const text = await response.text();

        const result = Papa.parse(text, {
            header: true,
            skipEmptyLines: true,
        });

        return result.data;
    } catch (err) {
        console.error("Error loading Coins:", err);
    }
}

