async function loadItems(csvFile){
    try {
        const response = await fetch("assets/" + csvFile);
        const text = await response.text();

        const result = Papa.parse(text, {
            header: true,
            skipEmptyLines: true,
        });

        return result.data;
    } catch (err) {
        console.error("Error loading Coins:", err);
    }
}

