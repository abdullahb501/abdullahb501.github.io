// Get Estimated Total Value
document.addEventListener("DOMContentLoaded", () => {
    loadCoins().then((coins) => {
        let penceCounter = 0;
        let poundsCounter = 0;
        let eurosCounter = 0;
        let euroCentsCounter = 0;
        coins.forEach((coin) => {
            let value = Number(coin.Denomination) * Number(coin.Quantity);
            switch (coin.Currency) {
                case "Pence":
                    penceCounter += value;
                    break;
                case "Pound":
                    poundsCounter += value;
                    break;
                case "Euro Cent":
                    euroCentsCounter += value;
                    break;
                case "Euro":
                    eurosCounter += value;
                    break;
                default:
                    break;
            }
        });
        let totalPounds = poundsCounter + penceCounter / 100;
        let totalEuros = eurosCounter + euroCentsCounter / 100;
        let total = totalPounds + (totalEuros * 0.87);
        document.getElementById("TotalContainer").innerHTML =
        `<p style="margin-left: 2em; border: .5em dash #000">Estimated Total Value : £${total.toFixed(2)} GBP</p>`;
    });
})





