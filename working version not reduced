async function displayCoinSearch(container, search){
let coinContainer = document.getElementById(container);
coinContainer.innerHTML = "";
let found = false;
    loadCoins().then((coins) => {
        coins.forEach((coin) => {
            const match =
            Object.values(coin).some(value =>
                value?.toString().toLowerCase().includes(search.toLowerCase())
            );
            if(!match) return;
            found = true;
            let card = document.createElement("div");
            card.innerHTML = `
                <img loading="lazy" class="coinImage" src="assets/images/firstLoad.png" width="75" height="75" alt="coinImage">
            `;
            const img = card.querySelector(".coinImage");
            loadCoinImages(coin.ID).then((blob) => {
                img.src = URL.createObjectURL(blob);
                card.title = "Name: " + coin.ID + "\n" + 
                "Year: " + coin.Year + "\n" +
                "Quantity: " + coin.Quantity
                card.style.padding="1em";
            });
            img.onerror = () => {
                card.style.display = "none";
            };
            coinContainer.appendChild(card);
        });
        document.getElementById("CoinSearchDisplaySeperation").style.display =
        found ? "block" : "none";
    });
}

